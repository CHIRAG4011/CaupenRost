# CaupenRost Bakery - Environment Configuration Template
# Copy this file to .env and fill in your values

# ===========================================
# MONGODB CONNECTION (Required)
# ===========================================

# For MongoDB Atlas (cloud) - Recommended:
# Sign up free at https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/caupenrost

# For Local MongoDB:
# MONGO_URI=mongodb://localhost:27017/caupenrost

# ===========================================
# FLASK CONFIGURATION (Required)
# ===========================================

# Secret key for session encryption (generate a secure random string)
SESSION_SECRET=your-super-secret-key-here-change-this-to-something-secure

# ===========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ===========================================

# Your Gmail address
GMAIL_EMAIL=your-email@gmail.com

# Gmail App Password (NOT your regular password!)
# How to get it:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and your device, click "Generate"
# 4. Copy the 16-character password (looks like: abcd efgh ijkl mnop)
GMAIL_APP_PASSWORD=your-16-character-app-password

# Flask-Mail settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ===========================================
# PAYMENT GATEWAY (Optional)
# ===========================================

# Razorpay credentials (for payment processing)
# Sign up at https://razorpay.com
# RAZORPAY_KEY_ID=your-razorpay-key-id
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
DEBUG=True

# ===========================================
# NOTES
# ===========================================
#
# MONGODB ATLAS SETUP (Free Tier):
# 1. Go to https://www.mongodb.com/atlas
# 2. Create free account and cluster
# 3. Create database user with password
# 4. Add your IP to Network Access (or 0.0.0.0/0 for development)
# 5. Get connection string from Connect > Connect your application
# 6. Replace <password> with your actual password
# 7. Add database name at the end: /caupenrost
#
# LOCAL MONGODB SETUP:
# Windows: Download installer from mongodb.com
# Mac: brew install mongodb-community && brew services start mongodb-community
# Linux: Follow instructions at docs.mongodb.com/manual/installation
#
# IMPORTANT: Never commit this file with real credentials to version control!
