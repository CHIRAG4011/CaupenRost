# CaupenRost - Environment Configuration Template
# Copy this to .env and fill in your values

# ===========================================
# REQUIRED SETTINGS
# ===========================================

# Secret key for session encryption (generate a secure random string)
SESSION_SECRET=your-super-secret-key-here-change-this-to-something-secure

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Flask environment: 'local', 'development', or 'production'
# 'local' = SQLite (simplest, no database setup needed)
# 'development' = PostgreSQL or SQLite with debug mode
# 'production' = PostgreSQL required
FLASK_ENV=local

# Option 1: SQLite (default for local development)
# Just set FLASK_ENV=local - no other database config needed!
# Database file will be created at: instance/caupenrost.db

# Option 2: PostgreSQL (full URL)
# DATABASE_URL=postgresql://username:password@localhost:5432/caupenrost

# Option 3: PostgreSQL (individual variables)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=your_username
# PGPASSWORD=your_password
# PGDATABASE=caupenrost

# ===========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ===========================================

# Your Gmail address
GMAIL_EMAIL=your-email@gmail.com

# Gmail App Password (NOT your regular password!)
# How to get it:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and your device, click "Generate"
# 4. Copy the 16-character password (looks like: abcd efgh ijkl mnop)
GMAIL_APP_PASSWORD=your-16-character-app-password

# Optional: Flask-Mail settings (uses Gmail SMTP by default)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
DEBUG=True

# ===========================================
# PRODUCTION SETTINGS (uncomment for production)
# ===========================================
# FLASK_ENV=production
# DEBUG=False

# ===========================================
# PORT CONFIGURATION
# ===========================================
# PORT=5000
